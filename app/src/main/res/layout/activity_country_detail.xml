<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/surface_bg">

    <!-- Header with back button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_deep"
        android:paddingLeft="12dp"
        android:paddingRight="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/text_white"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌍  Explore Countries"
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/text_white"
            android:layout_marginLeft="4dp" />

        <TextView
            android:id="@+id/txtCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 / 15"
            android:textSize="14sp"
            android:textColor="@color/accent_yellow"
            android:textStyle="bold"
            android:background="@drawable/badge_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

    <!-- Tap hint -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👆  Tap the card to reveal country info"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:paddingTop="10dp"
        android:paddingBottom="2dp" />

    <!-- Card container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <!-- FRONT: travel image fills the whole card, zero text overlay -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFront"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/primary_deep"
            app:cardElevation="12dp">

            <ImageView
                android:id="@+id/imgWorldCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/world_landmarks" />

            <!-- Invisible label kept only for Java reference -->
            <TextView
                android:id="@+id/txtFrontLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:text="Country #1" />

        </androidx.cardview.widget.CardView>

        <!-- BACK: country info — outline drawn programmatically in Java -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardBack"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="12dp"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="126dp"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="5dp">

                        <ImageView
                            android:id="@+id/flagImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:padding="6dp" />

                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/countryName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Turkey"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginBottom="4dp" />

                    <View
                        android:layout_width="40dp"
                        android:layout_height="3dp"
                        android:background="@color/accent_orange"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:id="@+id/capital"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏛️  Capital: Ankara"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👋  Greeting: Merhaba"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="14dp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardBackgroundColor="@color/primary_pale"
                        app:cardElevation="0dp">

                        <TextView
                            android:id="@+id/funFact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💡 Fun fact..."
                            android:textSize="20sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:lineSpacingMultiplier="1.4"
                            android:padding="14dp" />

                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="@color/primary_main"
                        app:cardElevation="4dp">

                        <Button
                            android:id="@+id/btnSpeak"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="🔊  Hear Greeting"
                            android:textSize="14sp"
                            android:textColor="@color/text_white"
                            android:textStyle="bold"
                            android:background="@drawable/btn_teal_ripple" />

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </ScrollView>

        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <!-- Nav buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="18dp"
        android:paddingRight="18dp"
        android:paddingBottom="24dp"
        android:paddingTop="8dp">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginRight="8dp"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="3dp">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="← Prev"
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:background="@drawable/btn_white_ripple" />

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginLeft="8dp"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="@color/accent_orange"
            app:cardElevation="6dp">

            <Button
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Next →"
                android:textSize="14sp"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:background="@drawable/btn_orange_ripple" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>