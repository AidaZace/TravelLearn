<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <!-- Hero Header -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="52dp"
        android:paddingBottom="36dp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:background="@color/primary_deep"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="20dp">
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/circle_ring_bg" />
            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:src="@drawable/logo"
                android:scaleType="fitCenter" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TravelLearn"
            android:textSize="38sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-black" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌍  Explore · Discover · Quiz"
            android:textSize="13sp"
            android:textColor="@color/primary_light"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Orange accent divider -->
    <View
        android:id="@+id/accentDivider"
        android:layout_width="0dp"
        android:layout_height="5dp"
        android:background="@color/accent_orange"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Buttons section -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/accentDivider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingLeft="24dp"
            android:paddingRight="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="32dp">

            <TextView
                android:id="@+id/txtLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  CHOOSE YOUR ADVENTURE  ✦"
                android:textSize="10sp"
                android:textColor="@color/text_secondary"
                android:letterSpacing="0.18"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardCountries"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_marginTop="22dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/accent_orange"
                app:cardElevation="8dp"
                app:layout_constraintTop_toBottomOf="@id/txtLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <Button
                    android:id="@+id/btnCountryDetails"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🌍  Learn Countries"
                    android:textSize="17sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-black"
                    android:background="@drawable/btn_orange_ripple" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardQuiz"
                android:layout_width="0dp"
                android:layout_height="65dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/primary_main"
                app:cardElevation="6dp"
                app:layout_constraintTop_toBottomOf="@id/cardCountries"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <Button
                    android:id="@+id/btnQuiz"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="❓  Start Quiz"
                    android:textSize="16sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:background="@drawable/btn_teal_ripple" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardLeaderboard"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cardQuiz"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <Button
                    android:id="@+id/btnLeaderboard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🏆  Leaderboard"
                    android:textSize="15sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:background="@drawable/btn_white_ripple" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSettings"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cardLeaderboard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">
                <Button
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="⚙️  Settings"
                    android:textSize="15sp"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:background="@drawable/btn_white_ripple" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌐  15 countries · flags · capitals · greetings"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/cardSettings"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>